# SMTP settings — all form submissions are sent to info@zonzoctech.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=info@zonzoctech.com
SMTP_PASS=your-app-password-or-mailbox-password
SMTP_TO=info@zonzoctech.com

# Chatbot AI — get a FREE key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-1.5-flash

# Alternative: OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
