# SMTP settings — all form submissions are sent to info@zonzoctech.com

# Google Workspace / Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=info@zonzoctech.com
SMTP_PASS=your-app-password-or-mailbox-password
SMTP_TO=info@zonzoctech.com

# Hosting/cPanel mail (if not Google):
# SMTP_HOST=mail.zonzoctech.com
# SMTP_PORT=465
# SMTP_USER=info@zonzoctech.com
# SMTP_PASS=your-mailbox-password
# SMTP_TO=info@zonzoctech.com
